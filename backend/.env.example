# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kniffel_tracker
DB_USER=kniffel_user
DB_PASS=CHANGE_ME

# JWT
JWT_SECRET=CHANGE_ME

# Encryption
ENCRYPTION_KEY=CHANGE_ME

# Initial admin (required on first start when no users exist)
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG

# Auth tokens & cookie session
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
# Optional separate refresh secret (falls back to JWT_SECRET if empty)
REFRESH_TOKEN_SECRET=
ACCESS_COOKIE_NAME=gl_access_token
REFRESH_COOKIE_NAME=gl_refresh_token
# strict|lax|none (none requires HTTPS)
COOKIE_SAMESITE=strict
# true|false (for IP-mode without SSL set false)
COOKIE_SECURE=true
# Optional cookie domain, e.g. .example.com
COOKIE_DOMAIN=

# Optional CORS allowlist for production (comma-separated, e.g. https://example.com,https://www.example.com)
CORS_ORIGIN=

# Auto-Update
UPDATE_MANIFEST_URL=https://api.github.com/repos/michaelnid/GameLibrary/releases/latest
UPDATE_ALLOWED_HOSTS=api.github.com,github.com,objects.githubusercontent.com
UPDATE_RUNNER_PATH=/usr/local/bin/game-library-updater
UPDATE_USE_SUDO=true
UPDATE_STATE_PATH=/var/lib/game-library/update-state.json
UPDATE_LOG_PATH=/var/log/game-library-updater.log

# Server Status / Reboot (optional)
SERVER_REBOOT_ENABLED=false
SERVER_REBOOT_COMMAND=sudo
SERVER_REBOOT_ARGS=/sbin/reboot

# Reverse proxy trust setting (recommended: 1 behind nginx)
TRUST_PROXY=1

# Server
PORT=3001
NODE_ENV=production

# Rate Limiting (pro IP-Adresse)
RATE_LIMIT_MAX=5000
RATE_LIMIT_WINDOW_MINUTES=15
